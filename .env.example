# Copy to .env and fill in real values. Do not commit .env.
# These are placeholders; none are real credentials.

# Supabase / Postgres data layer
SUPABASE_URL=<supabase-project-url>
SUPABASE_SERVICE_KEY=<supabase-service-role-key>
SUPABASE_ANON_KEY=<supabase-anon-key>

# Claude enrichment: summaries, topic sentences, tags
ANTHROPIC_API_KEY=<anthropic-api-key>

# Deployed classifier API
CLASSIFIER_API_URL=<classifier-api-url>
CLASSIFIER_API_KEY=<classifier-api-key>

# Optional: route Claude through the Space proxy
ANTHROPIC_BASE_URL=<anthropic-proxy-base-url>
PROXY_TOKEN=<shared-proxy-token>

# Streamlit dashboard write gate
CURATOR_PASSWORD=<dashboard-password>
