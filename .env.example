# Copy to .env and fill in real values. Do NOT commit .env (it is gitignored).
# These are placeholders — none are real credentials.

# --- Supabase (Postgres data layer) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key        # backend jobs (scrape/classify/push)
SUPABASE_ANON_KEY=your-anon-key                    # dashboard reads

# --- Anthropic (Claude enrichment: summaries, topic sentences, tags) ---
ANTHROPIC_API_KEY=<anthropic-api-key>

# --- Deployed classifier API (FastAPI on a Hugging Face Space) ---
CLASSIFIER_API_URL=https://owner-space.hf.space
CLASSIFIER_API_KEY=<classifier-api-key>     # only if the Space is private

# --- Optional: route Claude through the Space proxy (GitHub-runner workaround) ---
# Set both together. ANTHROPIC_BASE_URL points the Anthropic SDK at the Space;
# PROXY_TOKEN is the shared secret the proxy checks so only this pipeline can use it.
# ANTHROPIC_BASE_URL=https://owner-space.hf.space
# PROXY_TOKEN=your-shared-proxy-secret
