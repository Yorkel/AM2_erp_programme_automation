# Copy to .env and fill in real values. Do not commit .env.
# These are placeholders; none are real credentials.

# Supabase / Postgres data layer
SUPABASE_URL=<supabase-project-url>
SUPABASE_SERVICE_KEY=<supabase-service-role-key>
SUPABASE_ANON_KEY=<supabase-anon-key>

# LLM enrichment: summaries, topic sentences, tags.
# OpenAI is PRIMARY on the CI runner (the runner cannot reliably reach Claude);
# Claude is a best-effort fallback. Set ENRICH_PROVIDER=openai to select it.
ENRICH_PROVIDER=openai
OPENAI_API_KEY=<openai-api-key>
ANTHROPIC_API_KEY=<anthropic-api-key>

# Deployed classifier API
CLASSIFIER_API_URL=<classifier-api-url>
CLASSIFIER_API_KEY=<classifier-api-key>

# Optional: route the Claude FALLBACK through the Space proxy (runner can't reach
# Anthropic directly). Only used when Claude is invoked as a fallback.
ANTHROPIC_BASE_URL=<anthropic-proxy-base-url>
PROXY_TOKEN=<shared-proxy-token>

# Streamlit dashboard write gate
CURATOR_PASSWORD=<dashboard-password>
